<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="bars"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <logo_path
                        jcr:primaryType="nt:unstructured"
                        jcr:title="basictabs"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <logo_path
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Logo Path"
                                name="./logoPath"
                                rootPath="/content"/>
                            <logo_mobileimage
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Logo Mobileimage"
                                name="./logoMobileimage"
                                rootPath="/content"/>
                            <logo_link
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Logo Link"
                                name="./logoLink"
                                rootPath="/content"/>
                            <enable_switch
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                name="./enableSwitch"
                                text="Enable Switch"
                                uncheckedValue="false"
                                value="true"/>
                            <nodeNameTypeHint
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                name="./nodeName@TypeHint"
                                value="Boolean"/>
                        </items>
                    </logo_path>
                    <header_links
                        jcr:primaryType="nt:unstructured"
                        jcr:title="advancedtabs"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <project-title
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Project Title"
                                name="./project Title"/>
                            <required_fields
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                composite="{Boolean}true"
                                fieldLabel="Required fields">
                                <field
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    name="./requiredFields">
                                    <items jcr:primaryType="nt:unstructured">
                                        <enter_name
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                            fieldLabel="Enter Name"
                                            name="./enterName"/>
                                        <image
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                            fieldLabel="image"
                                            name="./image"
                                            rootPath="/content"/>
                                    </items>
                                </field>
                            </required_fields>
                        </items>
                    </header_links>
                    <sidebar_navigation
                        jcr:primaryType="nt:unstructured"
                        jcr:title="sidebar navigation"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <imp_fields
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                composite="{Boolean}true"
                                fieldLabel="imp fields">
                                <field
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    name="./impFields">
                                    <items jcr:primaryType="nt:unstructured">
                                        <desktop_icon
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                            fieldLabel="Desktop_icon"
                                            name="./desktopIcon"
                                            rootPath="/content"/>
                                        <mobile_icon
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                            fieldLabel="mobileicon"
                                            name="./mobileIcon"
                                            rootPath="/content"/>
                                    </items>
                                </field>
                            </imp_fields>
                        </items>
                    </sidebar_navigation>
                    <region
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Region"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <country
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="countries list"
                                name="./countryList">
                                <items jcr:primaryType="nt:unstructured">
                                    <us
                                        jcr:primaryType="nt:unstructured"
                                        text="usa"
                                        value="us"/>
                                    <in
                                        jcr:primaryType="nt:unstructured"
                                        text="india"
                                        value="in"/>
                                </items>
                            </country>
                        </items>
                    </region>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
