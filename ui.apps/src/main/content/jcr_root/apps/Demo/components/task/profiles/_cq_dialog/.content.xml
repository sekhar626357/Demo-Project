<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Profiles Component"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <layout
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/layouts/fixedcolumns"/>
        <items jcr:primaryType="nt:unstructured">
            <column
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">
                    <nameField
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="Name"
                        name="./name"/>
                    <imageDropdown
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                        fieldLabel="Select Image"
                        name="./selectedImage">
                        <datasource
                            jcr:primaryType="nt:unstructured"
                            sling:resource="/bin/image-dropdown"
                            sling:resourceType="granite/ui/components/coral/foundation/form/datasource"/>
                        <items jcr:primaryType="nt:unstructured">
                            <image1.jpg
                                jcr:primaryType="nt:unstructured"
                                text="image1"
                                value="image1.jpg"/>
                            <image2.jpg
                                jcr:primaryType="nt:unstructured"
                                text="image2"
                                value="image2.jpg"/>
                            <image3.jpg
                                jcr:primaryType="nt:unstructured"
                                text="image3"
                                value="image3.jpg"/>
                            <image4.jpg
                                jcr:primaryType="nt:unstructured"
                                text="image4"
                                value="image4.jpg"/>
                            <image5.jpg
                                jcr:primaryType="nt:unstructured"
                                text="image5"
                                value="image5.jpg"/>
                            <image6.jpg
                                jcr:primaryType="nt:unstructured"
                                text="image6"
                                value="image6.jpg"/>
                            <image7.jpg
                                jcr:primaryType="nt:unstructured"
                                text="image7"
                                value="image7.jpg"/>
                            <image8.jpg
                                jcr:primaryType="nt:unstructured"
                                text="image8"
                                value="image8.jpg"/>
                            <image9.jpg
                                jcr:primaryType="nt:unstructured"
                                text="image9"
                                value="image9.jpg"/>
                            <image10.jpg
                                jcr:primaryType="nt:unstructured"
                                text="image10"
                                value="image10.jpg"/>
                        </items>
                    </imageDropdown>
                </items>
            </column>
        </items>
    </content>
</jcr:root>
